{
  "name": "finora-server",
  "version": "1.0.0",
  "description": "Finora — Production-grade Express TypeScript backend for personal finance",
  "main": "src/app.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build:server": "esbuild src/server.ts --bundle --platform=node --target=node20 --outfile=dist/server.js --format=cjs --external:bcryptjs --external:cors --external:dotenv --external:express --external:express-mongo-sanitize --external:express-rate-limit --external:helmet --external:jsonwebtoken --external:mongoose --external:nodemailer --external:uuid --external:winston",
    "build:api": "esbuild api/index.ts --bundle --platform=node --target=node20 --outfile=api/index.js --format=cjs --external:bcryptjs --external:cors --external:dotenv --external:express --external:express-mongo-sanitize --external:express-rate-limit --external:helmet --external:jsonwebtoken --external:mongoose --external:nodemailer --external:uuid --external:winston",
    "build": "npm run build:server && npm run build:api",
    "start": "node dist/server.js",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "change-password": "tsx scripts/change-admin-password.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-auth": "^1.6.23",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "nodemailer": "^6.10.1",
    "uuid": "^11.0.3",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
